{
  "buildCommand": "pnpm --filter @workspace/tools-website run build",
  "outputDirectory": "artifacts/tools-website/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "env": {
    "NODE_ENV": "production",
    "BASE_PATH": "/"
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
